{
  "name": "universe-sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "wasm:physics":   "wasm-pack build rust/physics   --target web --out-dir ../../public/wasm/physics   --release",
    "wasm:terrain":   "wasm-pack build rust/terrain   --target web --out-dir ../../public/wasm/terrain   --release",
    "wasm:chemistry": "wasm-pack build rust/chemistry --target web --out-dir ../../public/wasm/chemistry --release",
    "wasm": "npm run wasm:physics && npm run wasm:terrain && npm run wasm:chemistry",
    "wasm:dev": "wasm-pack build rust/physics --target web --out-dir ../../public/wasm/physics --dev && wasm-pack build rust/terrain --target web --out-dir ../../public/wasm/terrain --dev && wasm-pack build rust/chemistry --target web --out-dir ../../public/wasm/chemistry --dev"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.1",
    "@clerk/react": "^6.1.1",
    "@dimforge/rapier3d-compat": "^0.12.0",
    "@neondatabase/serverless": "^1.0.2",
    "@react-three/drei": "^9.113.0",
    "@react-three/fiber": "^8.17.0",
    "@react-three/postprocessing": "^3.0.4",
    "@xyflow/react": "^12.10.1",
    "bitecs": "^0.3.40",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.0",
    "postprocessing": "^6.39.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.4"
  }
}
